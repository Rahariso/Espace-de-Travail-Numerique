<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the host points to the Laravel root instead of /public,
    # forward every non-file request into the public front controller.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
